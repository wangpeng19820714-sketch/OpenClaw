#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ $# -eq 0 ]]; then
  exec "${SCRIPT_DIR}/openclaw-restart"
fi

if [[ "$1" == "openclaw" || "$1" == "openclaw-restart" || "$1" == "openclaw_restart" ]]; then
  shift
  if [[ $# -eq 0 ]]; then
    exec "${SCRIPT_DIR}/openclaw-restart"
  fi
fi

exec "${SCRIPT_DIR}/openclaw-restart" "$@"
