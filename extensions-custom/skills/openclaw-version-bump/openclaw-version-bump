set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

get_repo_root() {
  local dir="$SCRIPT_DIR"

  while [[ -n "$dir" ]]; do
    if [[ -d "$dir/.git" ]] || [[ -f "$dir/.git" ]]; then
      echo "$dir"
      return 0
    fi

    local parent
    parent="$(dirname "$dir")"
    if [[ "$parent" == "$dir" ]]; then
      break
    fi
    dir="$parent"
  done

  return 1
}

REPO_ROOT="$(get_repo_root || true)"
if [[ -z "${REPO_ROOT:-}" ]]; then
  echo "ERR: cannot resolve repository root from $SCRIPT_DIR" >&2
  exit 1
fi

get_local_version() {
  node -p "require('${REPO_ROOT//\'/\'\\\'\'}/package.json').version"
}

sanitize_version() {
  printf "%s" "${1#v}"
}

get_latest_remote_tag() {
  local remote_tag
  remote_tag="$(git -C "$REPO_ROOT" ls-remote --tags --refs --sort='-v:refname' origin 'v*' 2>/dev/null \
    | awk '{print $2}' \
    | sed 's#refs/tags/##; s/\^{}$//' \
    | grep -E '^v[0-9]{4}\.[0-9]+\.[0-9]+($|[-.])' \
    | head -n 1 || true)"

  if [[ -n "$remote_tag" ]]; then
    printf "%s\n" "$remote_tag"
    return 0
  fi

  return 1
}

get_latest_local_tag() {
  local local_tag
  local_tag="$(git -C "$REPO_ROOT" tag --list 'v*' --sort=-version:refname \
    | grep -E '^v[0-9]{4}\.[0-9]+\.[0-9]+($|[-.])' \
    | head -n 1 || true)"

  if [[ -n "$local_tag" ]]; then
    printf "%s\n" "$local_tag"
    return 0
  fi

  return 1
}

print_current() {
  local current_version
  current_version="$(get_local_version)"
  echo "current_version=${current_version}"
}

print_latest() {
  if git -C "$REPO_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git -C "$REPO_ROOT" fetch --tags --force --prune --prune-tags 2>/dev/null || true
  fi

  local latest_tag=""
  latest_tag="$(get_latest_remote_tag || true)"
  if [[ -n "$latest_tag" ]]; then
    echo "latest_version=${latest_tag}"
    echo "latest_version_without_prefix=$(sanitize_version "$latest_tag")"
    return 0
  fi

  latest_tag="$(get_latest_local_tag || true)"
  if [[ -n "$latest_tag" ]]; then
    echo "latest_version=${latest_tag}"
    echo "latest_version_without_prefix=$(sanitize_version "$latest_tag")"
    echo "note=Fell back to local tags"
    return 0
  fi

  local local_version
  local_version="$(get_local_version)"
  echo "latest_version=${local_version}"
  echo "latest_version_without_prefix=$(sanitize_version "$local_version")"
  echo "note=No valid release tags found locally or on origin; using package.json version as fallback (${local_version})."
}

case "${1:-query}" in
  query|current|"")
    print_current
    ;;
  latest)
    print_latest
    ;;
  *)
    echo "Usage:"
    echo "  /openclaw_version_bump           # show current version from package.json"
    echo "  /openclaw_version_bump current    # show current version"
    echo "  /openclaw_version_bump latest     # try to fetch latest release tag"
    exit 1
    ;;
esac
